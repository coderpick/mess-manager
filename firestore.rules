rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Messes
    match /messes/{messId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.adminUid ||
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.adminUid;
    }

    // Meals
    match /meals/{mealId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        isMessAdmin(request.resource.data.messId)
      );
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isMessAdmin(resource.data.messId)
      );
      allow delete: if request.auth != null && 
        isMessAdmin(resource.data.messId);
    }

    // Bazaar
    match /bazaar/{bazaarId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        isMessMember(request.resource.data.messId);
      allow update: if request.auth != null &&
        isMessAdmin(resource.data.messId);
      allow delete: if request.auth != null && (
        isMessAdmin(resource.data.messId) ||
        resource.data.addedBy == request.auth.uid
      );
    }

    // Deposits
    match /deposits/{depositId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        isMessAdmin(request.resource.data.messId);
      allow update: if request.auth != null && 
        isMessAdmin(resource.data.messId) &&
        isMessAdmin(request.resource.data.messId);
      allow delete: if request.auth != null && 
        isMessAdmin(resource.data.messId);
    }

    function isMessAdmin(messId) {
      let messData = get(/databases/$(database)/documents/messes/$(messId)).data;
      return messData.adminUid == request.auth.uid ||
        ('admins' in messData && request.auth.uid in messData.admins);
    }

    function isMessMember(messId) {
      let messData = get(/databases/$(database)/documents/messes/$(messId)).data;
      return messData.adminUid == request.auth.uid ||
        ('admins' in messData && request.auth.uid in messData.admins) ||
        request.auth.uid in messData.members;
    }
  }
}
